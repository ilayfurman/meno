NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/meno
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
ALLOW_DEV_AUTH=true
DEV_FALLBACK_CLERK_USER_ID=dev-local-user
# Leave blank to allow importing from any domain (SSRF protections against
# private IPs/localhost still apply either way). URL import now falls back
# to AI extraction on pages without schema.org Recipe markup, so it no
# longer needs to be restricted to a pre-vetted list of sites. Set a
# comma-separated allowlist here if you want to cap it for cost control.
ALLOWED_IMPORT_DOMAINS=
GEN_RATE_LIMIT_PER_MINUTE=12
GEN_DAILY_LIMIT=100
MAX_AGENT_RECIPES=8
MAX_IMPORT_RESPONSE_BYTES=5242880
REQUEST_TIMEOUT_MS=10000
